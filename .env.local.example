# ─── Resend API Key für E-Mail-Versand ───
# Registrierung: https://resend.com
RESEND_API_KEY=re_your_api_key_here

# ─── Öffentliche URL der App (für QR-Codes und E-Mail-Links) ───
# Lokal: http://localhost:3000
# Produktion: https://cards.mpool.de
NEXT_PUBLIC_BASE_URL=https://your-domain.de

# ─── Admin-Passwort ───
# Mindestens 12 Zeichen, Groß-/Kleinbuchstaben und Zahlen
# Wird nach erstem Login automatisch als salted Hash gespeichert
ADMIN_PASSWORD=ChangeThisToSomethingSecure123

# ─── Session-Secret (64 zufällige Hex-Zeichen) ───
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# ─── Persistenter Storage für Laufzeitdaten und Uploads ───
# Lokal reicht der Default-Ordner "storage"
# Auf dem VPS besser z.B. /var/lib/mpool-cards
STORAGE_DIR=storage
